generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id            BigInt         @id @default(autoincrement()) @db.BigInt
  name          String
  slug          String         @unique
  industry      String
  timezone      String
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  users         User[]
  contacts      Contact[]
  deals         Deal[]
  activities    Activity[]
  authSessions  AuthSession[]
  weddings      Wedding[]
  weddingStates WeddingState[]

  @@map("organizations")
}

model User {
  id             BigInt        @id @default(autoincrement()) @db.BigInt
  organizationId BigInt        @map("organization_id") @db.BigInt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  firstName      String        @map("first_name")
  lastName       String        @map("last_name")
  passwordHash   String?       @map("password_hash")
  role           String
  status         String
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  contactsOwned  Contact[]     @relation("ContactOwner")
  activities     Activity[]
  sessions       AuthSession[] @relation("SessionUser")

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

model Contact {
  id             BigInt       @id @default(autoincrement()) @db.BigInt
  organizationId BigInt       @map("organization_id") @db.BigInt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  firstName      String       @map("first_name")
  lastName       String       @map("last_name")
  email          String
  phone          String?
  source         String?
  tags           String[]
  weddingDate    DateTime?    @map("wedding_date")
  leadStatus     String       @map("lead_status")
  ownerUserId    BigInt?      @map("owner_user_id") @db.BigInt
  ownerUser      User?        @relation("ContactOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deals          Deal[]
  activities     Activity[]

  @@index([organizationId])
  @@map("contacts")
}

model Deal {
  id                BigInt       @id @default(autoincrement()) @db.BigInt
  organizationId    BigInt       @map("organization_id") @db.BigInt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId         BigInt       @map("contact_id") @db.BigInt
  contact           Contact      @relation(fields: [contactId], references: [id], onDelete: Restrict)
  title             String
  stage             String
  status            String
  value             Float
  currency          String
  expectedCloseDate DateTime?    @map("expected_close_date")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  activities        Activity[]

  @@index([organizationId])
  @@map("deals")
}

model Activity {
  id             BigInt       @id @default(autoincrement()) @db.BigInt
  organizationId BigInt       @map("organization_id") @db.BigInt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         BigInt       @map("user_id") @db.BigInt
  user           User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  contactId      BigInt?      @map("contact_id") @db.BigInt
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId         BigInt?      @map("deal_id") @db.BigInt
  deal           Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  type           String
  title          String
  description    String?
  dueDate        DateTime?    @map("due_date")
  completed      Boolean      @default(false)
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("activities")
}

model AuthSession {
  id             BigInt       @id @default(autoincrement()) @db.BigInt
  userId         BigInt       @map("user_id") @db.BigInt
  user           User         @relation("SessionUser", fields: [userId], references: [id], onDelete: Cascade)
  organizationId BigInt       @map("organization_id") @db.BigInt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshToken   String       @unique @map("refresh_token")
  expiresAt      DateTime     @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([organizationId])
  @@map("auth_sessions")
}

model Pack {
  id          BigInt    @id @default(autoincrement()) @db.BigInt
  name        String
  description String
  price       Float
  weddings    Wedding[]

  @@map("packs")
}

model WeddingState {
  id             BigInt       @id @default(autoincrement()) @db.BigInt
  organizationId BigInt       @map("organization_id") @db.BigInt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String
  name           String
  sortOrder      Int          @map("sort_order")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  weddings       Wedding[]

  @@unique([organizationId, code])
  @@unique([organizationId, name])
  @@index([organizationId, sortOrder])
  @@map("wedding_states")
}

model Wedding {
  id             BigInt       @id @default(autoincrement()) @db.BigInt
  organizationId BigInt       @map("organization_id") @db.BigInt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name1          String       @map("name_1")
  lastName1      String       @map("last_name_1")
  name2          String       @map("name_2")
  lastName2      String       @map("last_name_2")
  email1         String       @map("email_1")
  email2         String?      @map("email_2")
  phone1         String?      @map("phone_1")
  phone2         String?      @map("phone_2")
  language       String?
  weddingDate    DateTime?    @map("wedding_date")
  location       String?
  stateId        BigInt       @map("state_id") @db.BigInt
  state          WeddingState @relation(fields: [stateId], references: [id], onDelete: Restrict)
  packId         BigInt?      @map("pack_id") @db.BigInt
  pack           Pack?        @relation(fields: [packId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([stateId])
  @@map("weddings")
}
